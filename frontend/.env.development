# 开发环境（Vite mode=development）
# [LUO-D01] 后端 FastAPI=8001；Chroma=8000，勿混用
# [LUO-F02] 开发期默认留空，走相对路径 + Vite 代理（勿写死绝对地址绕过 proxy）
VITE_API_BASE_URL=
VITE_API_PROXY=http://127.0.0.1:8001
VITE_APP_ENV=dev
# [LUO-F01] 默认关 Mock，避免联调假绿；演示请用 .env.local 或 npm run smoke:mock
VITE_USE_MOCK=false
# 会话列表/消息/删除走真实后端；创建会话仍本地生成 ID
VITE_CHAT_SESSION_API=true
# 可选：多前端并行时改端口，或启动加 --port 5174
# VITE_DEV_PORT=5174
