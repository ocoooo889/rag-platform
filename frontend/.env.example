# 前端环境变量说明（可复制为 .env.local 覆盖，勿提交密钥）
#
# VITE_API_BASE_URL  — Axios baseURL（直连后端时填写，如 http://127.0.0.1:8001）
# VITE_API_PROXY     — Vite 开发代理目标（测试报告约定；默认 http://127.0.0.1:8001）
#                      兼容旧名 VITE_API_PROXY_TARGET
# VITE_USE_MOCK      — true 开启应用层 Mock；false 走真实 HTTP/SSE（默认建议联调时 false）
#                      兼容旧名 VITE_MOCK_OPEN
# VITE_DEV_PORT      — 开发端口，默认 5173；并行可用 5174
# VITE_APP_ENV       — 业务环境标识

VITE_API_BASE_URL=http://127.0.0.1:8001
VITE_API_PROXY=http://127.0.0.1:8001
VITE_APP_ENV=dev
VITE_USE_MOCK=true
