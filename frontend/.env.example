# 前端环境变量说明（可复制为 .env.local 覆盖，勿提交密钥）
#
# VITE_API_BASE_URL  — Axios baseURL。开发建议留空，走 Vite /api 代理（LUO-F02）
#                      仅在需直连后端（绕过 proxy）时填写，如 http://127.0.0.1:8001
# VITE_API_PROXY     — Vite 开发代理目标（默认 http://127.0.0.1:8001，勿用 8000）
# VITE_USE_MOCK      — true=应用层 Mock；false=真实后端（development 默认 false，LUO-F01）
#                      演示 Mock：在 .env.local 写 VITE_USE_MOCK=true
#                      冒烟：npm run smoke:mock（使用 .env.mock）
# VITE_DEV_PORT      — 开发端口，默认 5173；并行可用 5174
# VITE_APP_ENV       — 业务环境标识
# VITE_CHAT_SESSION_API — true 时请求真后端会话 CRUD（默认 false，LUO-F03 本地会话）

VITE_API_BASE_URL=
VITE_API_PROXY=http://127.0.0.1:8001
VITE_APP_ENV=dev
VITE_USE_MOCK=false
# VITE_CHAT_SESSION_API=true
