# 环境变量说明（可复制为 .env.local 覆盖本地配置，勿提交密钥）
#
# VITE_API_BASE_URL — 全局 API 基础地址，由 src/utils/request.js 读取
# VITE_APP_ENV — 业务环境标识
# VITE_MOCK_OPEN — true 时所有 api/* 走契约对齐 Mock；SSE 用定时器分段推送
#                  false 时走真实 HTTP / fetch SSE（逻辑保留不删除）

VITE_API_BASE_URL=http://127.0.0.1:8001
VITE_APP_ENV=dev
VITE_MOCK_OPEN=true
