# ===== 智能 RAG 平台 · 环境变量模板 =====
# 使用前： cp .env.example .env
# 每人必须改 ENV、API Key 为自己内容

# ===== 个人开发环境标识（每人不同，必须改）=====
ENV=dev-你的姓名拼音

# ===== 个人独立资源路径 =====
LOCAL_DB_NAME=dev_你的姓名拼音_rag.db
CHROMA_COLLECTION_SUFFIX=_你的姓名拼音
UPLOAD_DIR=./uploads/dev_你的姓名拼音

# ===== LLM / Embedding API Key（每人用自己的 Key，避免共用触发限流）=====
OPENAI_API_KEY=sk-xxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# ===== Chroma 服务地址（所有人统一）=====
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ===== 全局超时配置 =====
LLM_TIMEOUT=10
EMBEDDING_TIMEOUT=10

# ===== JWT 密钥（开发环境固定，生产环境请更换）=====
JWT_SECRET=rag-platform-secret-key-change-in-production

# ===== V2 新增：Langfuse 配置（后端 A；不填则本地跳过上报）=====
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
LANGFUSE_HOST=http://localhost:3000

# ===== V2 新增：Prometheus 配置（后端 B 使用）=====
PROMETHEUS_ENABLED=true
METRICS_PATH=/metrics
