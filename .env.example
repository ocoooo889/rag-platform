# ===== 智能 RAG 平台 · 环境变量模板 =====
# 使用前： cp .env.example .env
# 每人必须改 ENV、API Key 为自己内容

# ===== 个人开发环境标识（每人不同，必须改）=====
ENV=dev-你的姓名拼音

# ===== 个人独立资源路径 =====
LOCAL_DB_NAME=dev_你的姓名拼音_rag.db
CHROMA_COLLECTION_SUFFIX=_你的姓名拼音
UPLOAD_DIR=./uploads/dev_你的姓名拼音

# ===== LLM / Embedding API Key（每人用自己的 Key，避免共用触发限流）=====
OPENAI_API_KEY=sk-xxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# ===== Chroma 服务地址（须与启动参数一致）=====
# 启动：chroma run --path ./chroma_data --host 127.0.0.1 --port 8000
# Windows 勿用默认 localhost（常只绑 ::1，导致 127.0.0.1 连不上 → 关键词降级）
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8000

# ===== 全局超时 / 长文档向量化 =====
LLM_TIMEOUT=60
EMBEDDING_TIMEOUT=90
EMBEDDING_BATCH_SIZE=10
EMBEDDING_MAX_RETRIES=4
CHROMA_WRITE_BATCH_SIZE=100
# 可选：长文档可把 CHUNK_SIZE 调到 800~1000 减少切片数（默认 500）
# CHUNK_SIZE=500
# CHUNK_OVERLAP=50

# ===== 对话检索策略（验收语义 RAG 请用 balanced）=====
# fast=对话直接 BM25；balanced=真向量（超时回退 BM25）；quality=尽量等向量
CHAT_RETRIEVE_MODE=balanced
CHAT_VECTOR_TIMEOUT=10
HITTEST_VECTOR_TIMEOUT=10
# STALE_PROCESSING_MINUTES=30

# ===== JWT 密钥（开发环境固定，生产环境请更换）=====
JWT_SECRET=rag-platform-secret-key-change-in-production

# ===== V2 新增：Langfuse 配置（不填或占位 xxxxxxxx 则跳过上报，勿填假 Key）=====
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# ===== V2 新增：Prometheus 配置（后端 B 使用）=====
PROMETHEUS_ENABLED=true
METRICS_PATH=/metrics
